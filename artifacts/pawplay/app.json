{
  "expo": {
    "name": "Quick-mix",
    "slug": "pawplay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/mainIcon.png",
    "scheme": "pawplay",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/mainIcon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F3EF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.quickmix.pawplay",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.quickmix.pawplay",
      "versionCode": 1,
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "extra": {
      "eas": {
        "projectId": "edca0086-a92b-45df-94be-985715d7d2ff"
      }
    },
    "web": {
      "favicon": "./assets/images/mainIcon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Quick-mix to access your photos to set a profile picture for your dog."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "alanohcz"
  }
}
